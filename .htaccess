RewriteEngine On

# 1. .php वाले URL को बिना एक्सटेंशन वाले URL पर परमानेंटली (301) रीडायरेक्ट करें
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. बिना एक्सटेंशन वाले URL को बैकएंड में उसकी असली .php फाइल से मैप करें
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]